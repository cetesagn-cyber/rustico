# ── Base de datos de TEST (PostgreSQL) ─────────────────────────────────────────
# Cambia la contraseña y el host según tu instalación local de PostgreSQL.
# Esta base de datos (rustico_test) se crea y destruye automáticamente en cada
# ejecución del suite. NO la uses en producción.
DATABASE_URL=postgresql://postgres:Rustico.2030@localhost:5432/rustico_test

# ── JWT ─────────────────────────────────────────────────────────────────────────
JWT_SECRET=test-secret-for-jwt-signing-minimum-32-chars-rustico-qa
JWT_EXPIRY=1h

# ── App ─────────────────────────────────────────────────────────────────────────
NODE_ENV=test
PORT=3099
FRONTEND_URL=http://localhost:5180
