# Base de datos de TEST (PostgreSQL)
# Cambia la contrasena y el host segun tu instalacion local de PostgreSQL.
# Esta base de datos (rustico_test) se crea y destruye automaticamente en cada
# ejecucion del suite. NO la uses en produccion.
DATABASE_URL=postgresql://postgres:password@localhost:5432/rustico_test

# JWT
JWT_SECRET=test-secret-for-jwt-signing-minimum-32-chars-rustico-qa
JWT_EXPIRY=1h

# App
NODE_ENV=test
PORT=3099
FRONTEND_URL=http://localhost:5180
